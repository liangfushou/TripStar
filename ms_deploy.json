{
    "$schema": "https://modelscope.cn/api/v1/studios/deploy_schema.json",
    "sdk_type": "docker",
    "resource_configuration": "platform/2v-cpu-16g-mem",
    "port": 7860,
    "environment_variables": [
        {
            "name": "LLM_MODEL_ID",
            "value": "your-model-name"
        },
        {
            "name": "LLM_API_KEY",
            "value": "your-api-key-here"
        },
        {
            "name": "LLM_BASE_URL",
            "value": "your-api-base-url"
        },
        {
            "name": "LLM_TIMEOUT",
            "value": "600"
        },
        {
            "name": "AMAP_API_KEY",
            "value": "your_amap_api_key_here"
        },
        {
            "name": "UNSPLASH_ACCESS_KEY",
            "value": "your_unsplash_access_key"
        },
        {
            "name": "UNSPLASH_SECRET_KEY",
            "value": "your_unsplash_secret_key"
        },
        {
            "name": "HOST",
            "value": "0.0.0.0"
        },
        {
            "name": "PORT",
            "value": "7860"
        },
        {
            "name": "CORS_ORIGINS",
            "value": "*"
        },
        {
            "name": "LOG_LEVEL",
            "value": "INFO"
        }
    ]
}